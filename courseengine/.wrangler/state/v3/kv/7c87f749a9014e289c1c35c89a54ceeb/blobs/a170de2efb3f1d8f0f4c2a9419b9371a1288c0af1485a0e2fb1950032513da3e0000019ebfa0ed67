    {
      "term": "First flush",
      "definition": "The first spring harvest of the tea season, typically March–April in Darjeeling. Prized for freshness, delicacy, and bright aromatics."
    },
    {
      "term": "Second flush",
      "definition": "The summer harvest, typically June in Darjeeling. Fuller-bodied than first flush; associated with the signature muscatel (musky, apricot-stone) character of Darjeeling tea."
    },
    {
      "term": "Orange Pekoe (OP)",
      "definition": "A leaf grade describing whole, unbroken tea leaves. Not a flavour descriptor, not a type of tea, and not related to citrus. The 'orange' likely refers to the Dutch House of Orange or to the golden colour of budding tips."
    },
    {
      "term": "CTC (Cut-Tear-Curl)",
      "definition": "A mechanical processing method that cuts tea leaves into small, uniform pellets. Produces consistent, fast-infusing, strong teas. The basis of most commercial tea bags and Assam/Kenyan export blends."
    },
    {
      "term": "Orthodox processing",
      "definition": "Traditional whole-leaf processing that preserves leaf integrity through hand or mechanical rolling. Produces more complex, nuanced teas than CTC, with wider flavour range per infusion."
    },
    {
      "term": "Fixation (Sha Qing)",
      "definition": "The application of heat to deactivate polyphenol oxidase enzymes and halt oxidation, locking in the green, fresh character of the leaf. Used in green, yellow, and some white teas."
    },
    {
      "term": "Pan-firing",
      "definition": "The Chinese method of fixation using a hot wok or rotating drum. Creates characteristic toasty, nutty, or chestnut notes in the finished tea."
    },
    {
      "term": "Steaming",
      "definition": "The Japanese method of fixation using a brief blast of steam. Preserves a brighter green colour and more pronounced vegetal, seaweed, and umami notes than pan-firing."
    },
    {
      "term": "Men huan",
      "definition": "The 'smothering' step unique to yellow tea production: fixed leaves are loosely wrapped in warm, humid conditions for a short period, producing a mellow secondary transformation that reduces grassiness and adds smoothness."
    },
    {
      "term": "Withering",
      "definition": "The first post-harvest step: freshly plucked leaves are spread out to lose moisture. Softens the leaf for rolling and initiates very mild enzymatic activity."
