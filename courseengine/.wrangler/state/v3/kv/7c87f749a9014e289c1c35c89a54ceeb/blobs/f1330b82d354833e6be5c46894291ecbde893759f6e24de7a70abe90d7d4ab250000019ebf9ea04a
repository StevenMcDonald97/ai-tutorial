                {
                  "optionIndex": 1,
                  "feedback": "Not independent: the seller grading its own homework is a textbook conflict of interest."
                },
                {
                  "optionIndex": 2,
                  "feedback": "Correct — many independent trials, pooled, dilute any single source's bias."
                },
                {
                  "optionIndex": 3,
                  "feedback": "Popularity measures spread, not truth — likes are not evidence."
                }
              ],
              "feedback": {
                "type": "elaborative",
