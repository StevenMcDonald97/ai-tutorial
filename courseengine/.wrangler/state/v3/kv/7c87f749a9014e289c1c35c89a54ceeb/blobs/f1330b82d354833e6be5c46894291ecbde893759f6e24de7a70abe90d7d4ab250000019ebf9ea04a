  "glossary": [
    {
      "term": "Confounder",
      "definition": "A hidden third variable that influences both of two correlated variables, creating the illusion that one causes the other."
    },
    {
      "term": "Correlation",
      "definition": "A measurable tendency for two variables to move together. It supports prediction but does not, by itself, establish cause."
    },
    {
      "term": "Base rate",
      "definition": "The underlying frequency of an event in a population — the statistical backdrop that vivid anecdotes tend to make us ignore."
    },
    {
      "term": "Reverse causation",
      "definition": "When the presumed effect is actually the cause; the causal arrow points the opposite way from what's claimed."
    },
    {
      "term": "Meta-analysis",
      "definition": "A study that statistically combines results from many independent studies to estimate an overall effect with greater reliability."
    },
    {
      "term": "Transfer",
      "definition": "Applying a skill learned in one context to a genuinely novel situation — the real test of understanding."
    }
  ]
