              "blockId": "cb-q3",
              "type": "interactive",
              "content": "Interactive widget: drag a slider between 'one vivid anecdote' and 'aggregate data from 10,000 cases' and watch the estimated reliability update."
            }
          ],
          "interactionSequence": [
            {
              "interactionId": "int-likert-1",
              "interactionType": "reflection",
              "prompt": "How often do you catch yourself swayed by a single memorable example over the broader data?",
              "required": false,
              "responseFormat": "likert",
