        {
          "experienceId": "exp-confounders",
          "title": "Hunting the Hidden Variable",
          "experienceType": "case-study",
          "difficultyProfile": {
            "overall": 3,
            "conceptualComplexity": 4,
            "ambiguity": 4
          },
          "estimatedDurationMinutes": 22,
