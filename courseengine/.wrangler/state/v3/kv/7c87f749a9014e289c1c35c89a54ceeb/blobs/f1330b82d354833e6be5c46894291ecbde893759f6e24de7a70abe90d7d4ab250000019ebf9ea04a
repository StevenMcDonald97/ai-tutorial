            {
              "interactionId": "int-mc-q",
              "interactionType": "multiple-choice",
              "prompt": "Two claims about a drug's safety conflict. Which source should generally carry the most weight?",
              "required": true,
              "responseFormat": "multiple-choice",
              "revealCondition": "after-response",
              "options": [
                "A heartfelt testimonial from someone harmed by the drug",
                "A manufacturer's press release citing its own trial",
                "A meta-analysis pooling many independent randomized trials",
                "A viral social media thread with thousands of likes"
              ],
              "correctIndex": 2,
              "optionFeedback": [
                {
                  "optionIndex": 0,
                  "feedback": "Vivid, but a single unrepresentative case — exactly the anecdote trap.",
                  "linkedMisconceptionId": "mis-vivid"
