      "sectionId": "sec-foundations",
      "title": "When Two Things Move Together",
      "description": "Correlation feels like causation. This section builds the reflex of stopping at the gap between them.",
      "learningObjectives": [
        {
          "objectiveId": "obj-1",
          "description": "Explain why correlation does not establish causation.",
          "linkedCompetencies": [
            "causal-reasoning"
          ]
        },
        {
          "objectiveId": "obj-2",
          "description": "Generate alternative explanations for an observed association.",
          "linkedCompetencies": [
            "causal-reasoning"
          ]
        }
      ],
      "motivationHooks": [
        {
          "type": "real-world-stakes",
          "prompt": "A health agency once urged millions to take hormone therapy based on correlational data. A later randomized trial found it raised the very risks it was meant to lower."
        },
        {
