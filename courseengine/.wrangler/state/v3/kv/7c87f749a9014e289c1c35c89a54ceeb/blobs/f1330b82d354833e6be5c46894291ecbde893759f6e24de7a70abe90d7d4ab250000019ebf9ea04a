      ],
      "learningExperiences": [
        {
          "experienceId": "exp-correlation",
          "title": "The Gap Between Together and Because",
          "experienceType": "guided-analysis",
          "difficultyProfile": {
            "overall": 2,
            "conceptualComplexity": 3,
            "ambiguity": 3
          },
          "estimatedDurationMinutes": 18,
          "linkedCompetencies": [
            "causal-reasoning"
          ],
          "desiredCognitiveActions": [
            "prediction",
            "analysis",
            "reflection"
          ],
          "contentBlocks": [
            {
              "blockId": "cb-1",
              "type": "text",
              "content": "Two variables are <em>correlated</em> when they move together in a predictable way. That is all correlation tells you — that knowing one helps you predict the other. It says nothing about <em>why</em>. The word <span class='glossary-link' data-term='confounder'>confounder</span> names the most common reason a correlation misleads: a hidden third variable driving both."
            },
            {
              "blockId": "cb-2",
              "type": "text",
              "content": "Consider ice cream and drowning. Both rise in summer. Heat is the shared cause; neither ice cream nor swimming drives the other. The correlation is real, the causal story invented."
            },
            {
              "blockId": "cb-3",
              "type": "image",
              "url": "",
              "altText": "A scatter plot of ice cream sales against drowning incidents, with a third arrow labelled 'summer heat' pointing at both — illustrating a confounding variable."
            }
          ],
          "interactionSequence": [
            {
              "interactionId": "int-pred-1",
              "interactionType": "prediction",
              "prompt": "A town notices that neighborhoods with more streetlights report more crime. Before reading the analysis: write one causal story AND one non-causal story that could explain this.",
              "required": true,
              "responseFormat": "short-answer",
              "revealCondition": "after-response",
              "feedback": {
                "type": "elaborative",
                "elaborativeFeedback": "The tempting causal story — 'lights attract criminals' — is rarely the real one. The usual non-causal explanation is reverse selection: cities install more lights in areas that already have high crime. The streetlights are a <em>response</em> to crime, not a cause of it. Whenever you see an association, ask which direction the arrow actually points, and whether something chose to put the two together."
              },
              "confidencePrompt": {
                "enabled": true,
                "scaleMin": 1,
                "scaleMax": 5,
                "prompt": "How confident are you that you found a genuine alternative explanation?"
              }
            },
            {
              "interactionId": "int-mc-1",
              "interactionType": "multiple-choice",
              "prompt": "Which statement correctly describes what a strong positive correlation between A and B licenses you to conclude?",
              "required": true,
              "responseFormat": "multiple-choice",
              "revealCondition": "after-response",
              "options": [
                "A causes B",
                "B causes A",
                "Knowing A improves your prediction of B — nothing more, on its own",
                "A and B are unrelated"
              ],
              "correctIndex": 2,
              "optionFeedback": [
                {
                  "optionIndex": 0,
                  "feedback": "This is the classic leap — the correlation is equally consistent with B causing A, or a shared cause driving both.",
                  "linkedMisconceptionId": "mis-corr-cause"
                },
                {
                  "optionIndex": 1,
                  "feedback": "Reversing the arrow is just as unsupported as the original claim — the data alone cannot pick a direction.",
                  "linkedMisconceptionId": "mis-corr-cause"
                },
                {
                  "optionIndex": 2,
                  "feedback": "Right: correlation licenses prediction, nothing more, until other evidence rules out the alternatives."
                },
                {
                  "optionIndex": 3,
                  "feedback": "A strong correlation means they ARE statistically related — the open question is why."
                }
              ],
              "feedback": {
                "type": "corrective",
                "correctiveFeedback": "Correlation is a statement about prediction, not mechanism. On its own it is equally consistent with A→B, B→A, a shared cause, or coincidence. Only additional evidence — an experiment, a ruled-out confounder, a mechanism — can choose among them."
              }
            },
            {
              "interactionId": "int-ref-1",
              "interactionType": "reflection",
              "prompt": "Think of a causal claim you currently believe based mostly on things 'going together.' How would you test whether it survives the alternative-explanations check?",
              "required": false,
              "responseFormat": "short-answer",
              "revealCondition": "on-request",
              "feedback": {
                "type": "socratic",
                "hints": [
                  "What would you expect to see if the arrow pointed the other way?",
                  "Is there a third factor that could plausibly drive both?",
                  "What experiment, even a thought experiment, would separate the explanations?"
                ]
              }
            }
          ],
          "workedExamples": [
            {
              "exampleId": "we-1",
              "problem": "A headline reads: 'People who drink red wine live longer — so pour a glass for your health.' Evaluate the causal claim.",
              "steps": [
                "Identify the association: moderate wine drinkers show longer average lifespans in observational data.",
                "Ask about direction: longevity can't cause past drinking, so reverse causation is unlikely here.",
                "Hunt for confounders: moderate drinkers tend to be wealthier, more socially connected, and have steadier routines — all independently linked to longevity.",
                "Check who was excluded: many studies lump lifelong abstainers with former heavy drinkers who quit due to illness, dragging down the 'no wine' group.",
                "Weigh the evidence type: this is observational, not a randomized trial."
              ],
              "conclusion": "The longevity gap is plausibly explained by who chooses to drink moderately, not by the wine itself. The claim outruns its evidence."
            }
          ],
