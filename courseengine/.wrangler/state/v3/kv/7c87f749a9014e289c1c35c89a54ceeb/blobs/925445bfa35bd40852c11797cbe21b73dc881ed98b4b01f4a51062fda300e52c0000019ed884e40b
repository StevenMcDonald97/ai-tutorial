      "commonMisconceptions": [
        {
          "misconceptionId": "misc-02-resistance-fixed",
          "misconception": "Some people just don't like boardgames \u2014 resistance is a stable personality trait, not a diagnosable and addressable condition.",
          "whyIncorrect": "Resistance is almost always specific: a bad past experience, a specific mechanism fear, social anxiety about public failure, or an identity conflict. All five reluctance types have known remedies.",
          "remediationStrategy": "Have the learner recall a friend previously written off as 'not a boardgame person' and retroactively apply the five-type framework. Most learners identify a specific type once prompted.",
          "linkedErrorPatterns": [
            "ep-02-fixed-resistance",
            "ep-02-give-up-early"
          ]
        },
        {
          "misconceptionId": "misc-02-explain-more",
          "misconception": "If a friend seems hesitant, explaining the rules more thoroughly or more clearly will overcome their reluctance.",
          "whyIncorrect": "Over-explanation is often the cause of reluctance, not the cure. For complexity aversion, a longer explanation confirms the threat. For social anxiety, it adds to the public failure risk.",
          "remediationStrategy": "Show a side-by-side comparison of a long rule explanation versus a 3-minute teach-and-play approach. Ask the learner to predict how a complexity-averse friend would respond to each.",
          "linkedErrorPatterns": [
            "ep-02-over-explain",
            "ep-02-teach-as-pitch"
