        },
        {
          "misconceptionId": "misc-02-trivia-maps-to-games",
          "misconception": "Friends who enjoy trivia nights will naturally enjoy boardgames because both involve competitive group play.",
          "whyIncorrect": "Trivia night fans enjoy social performance and knowledge competition, not mechanism engagement. They may strongly resist mechanism-heavy games while thriving in social deduction or party games.",
          "remediationStrategy": "Have the learner profile a hypothetical trivia night fan using the five-type framework and the four-axis model. Ask: 'Which games from your collection would match this profile?' The answer will be narrow.",
          "linkedErrorPatterns": [
            "ep-02-trivia-equivalence"
