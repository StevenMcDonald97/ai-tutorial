    "probeQuestions": [
      {
        "probeId": "probe-01",
        "prompt": "A friend tells you they loved playing 'The Resistance' at a party and asks you to recommend something similar. What should be your primary consideration when choosing a recommendation?",
        "questionType": "multiple-choice",
        "options": [
          "Find a game with a similar spy or thriller theme so the aesthetic matches what they enjoyed.",
          "Find a game with the same core mechanism \u2014 hidden roles and social deduction \u2014 regardless of theme.",
          "Recommend the most acclaimed game of the past year, since quality is the main driver of enjoyment.",
          "Recommend any game with the same number of players as The Resistance."
        ],
        "correctIndex": 1,
        "optionFeedback": [
          {
            "optionIndex": 0,
            "feedback": "Theme is a poor predictor of enjoyment \u2014 mechanism drives the experience. A player who loved The Resistance loved the social deduction, hidden information, and bluffing, not the spy setting.",
            "linkedMisconceptionId": "misc-01-theme-primary"
          },
          {
            "optionIndex": 1,
            "feedback": "Correct. Mechanism is the most reliable predictor of whether someone will enjoy a game. Matching on social deduction targets the actual source of enjoyment."
          },
          {
            "optionIndex": 2,
            "feedback": "Critical acclaim is a general quality signal but tells you nothing about fit to this specific person's enjoyment profile.",
            "linkedMisconceptionId": "misc-01-heavy-equals-good"
          },
          {
            "optionIndex": 3,
            "feedback": "Player count is one consideration but not the primary one. A game with the right player count but a completely different mechanism would likely disappoint.",
            "linkedMisconceptionId": "misc-01-theme-primary"
          }
        ],
        "linkedCompetencies": [
          "COMP-01"
        ],
        "scoringCriteria": [
          "Learner selects mechanism-matching as the primary criterion for recommendation."
        ],
        "routingRules": [
