  "competencies": [
    {
      "competencyId": "COMP-01",
      "title": "Boardgame Categorization and Fluency",
      "description": "The ability to accurately classify boardgames by mechanism, weight, play time, player count, and theme, and to explain meaningful differences between categories in plain language accessible to non-enthusiasts.",
      "taxonomyLevel": "analyze",
      "difficultyProfile": {
        "overall": 2,
        "conceptualComplexity": 2,
        "ambiguity": 2,
        "technicalSkill": 1,
        "readingDemand": 2
      },
      "transferRequired": true,
      "masteryThreshold": 0.85,
      "desiredOutcomes": [
        {
          "outcomeId": "out-01-A",
          "description": "Classify any given boardgame into at least one mechanism category and justify the classification with reference to what players actually do.",
          "verifiedBy": [
            "asmt-01",
            "asmt-capstone"
          ],
          "verificationCriteria": {
            "minimumAccuracy": 0.85,
            "minimumConfidenceCalibration": 0.75,
            "requiresTransferSuccess": true
          }
        },
        {
          "outcomeId": "out-01-B",
          "description": "Distinguish weight, play time, and theme as independent axes and explain the consequence of conflating them for real recommendations.",
          "verifiedBy": [
            "asmt-01"
          ],
          "verificationCriteria": {
            "minimumAccuracy": 0.8,
            "minimumConfidenceCalibration": 0.7,
            "requiresTransferSuccess": false
          }
        },
        {
          "outcomeId": "out-01-C",
          "description": "Identify the player-count range and session-length category for at least six canonical gateway, mid-weight, and party games.",
          "verifiedBy": [
            "asmt-01"
          ],
          "verificationCriteria": {
            "minimumAccuracy": 0.85,
            "minimumConfidenceCalibration": 0.7,
            "requiresTransferSuccess": false
          }
        },
        {
          "outcomeId": "out-01-D",
          "description": "Describe what a non-gamer is likely to perceive as appealing or threatening about a specific game based on its category profile.",
          "verifiedBy": [
            "asmt-01",
            "asmt-02"
          ],
          "verificationCriteria": {
            "minimumAccuracy": 0.8,
            "minimumConfidenceCalibration": 0.7,
            "requiresTransferSuccess": true
          }
        }
      ],
      "commonMisconceptions": [
        {
          "misconceptionId": "misc-01-theme-primary",
          "misconception": "Theme is the most important dimension when recommending a game \u2014 match on pirates, fantasy, or space and the friend will enjoy it.",
          "whyIncorrect": "Mechanism \u2014 what players are actually doing each turn \u2014 is the strongest predictor of enjoyment. A person who hated Monopoly dislikes the mechanism of player elimination and prolonged downtime, not the economic theme. Matching on theme while ignoring mechanism produces consistently poor recommendations.",
          "remediationStrategy": "Resurface worked examples (Azul, Root). Have the learner re-classify two games they recommended poorly using only the four-axis framework. Ask: 'What did your friend actually spend 80% of the session doing?'",
          "linkedErrorPatterns": [
            "ep-01-theme-match",
            "ep-01-theme-pitch"
          ]
        },
        {
          "misconceptionId": "misc-01-heavy-equals-good",
          "misconception": "Heavier, more complex games are better or more worthy of recommendation \u2014 weight signals quality and seriousness.",
          "whyIncorrect": "Weight is cognitive load, not quality. Codenames (weight ~1.5) is one of the most critically acclaimed designs of the past decade. The right weight is the weight that matches the audience, never the heaviest available option.",
          "remediationStrategy": "Present a table of critically acclaimed games across the weight spectrum. Have the learner rank three games by weight and by likely newcomer enjoyment \u2014 the two rankings will differ, making axis independence concrete.",
          "linkedErrorPatterns": [
            "ep-01-weight-quality",
            "ep-01-heavy-recommend"
          ]
        },
        {
          "misconceptionId": "misc-01-party-equals-gateway",
          "misconception": "Party games and gateway games are the same \u2014 both are 'easy' games suitable for introducing someone to the hobby.",
          "whyIncorrect": "Party games prioritise social energy over mechanism engagement. Gateway games introduce genuine mechanisms with meaningful decisions. Recommending Codenames to someone who would thrive in Ticket to Ride, or vice versa, produces the wrong experience for the wrong person.",
          "remediationStrategy": "Have the learner recall or play one party game and one gateway game back-to-back, then articulate the structural difference in what the player is asked to do.",
          "linkedErrorPatterns": [
            "ep-01-category-conflation"
          ]
        }
      ]
    },
    {
