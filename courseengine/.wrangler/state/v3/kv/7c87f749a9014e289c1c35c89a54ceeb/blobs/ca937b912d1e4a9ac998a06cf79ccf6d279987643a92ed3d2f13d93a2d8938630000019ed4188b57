  "glossary": [
    {
      "term": "Round",
      "definition": "A single image-and-guess cycle within a TimeGuesser session."
    },
    {
      "term": "Session",
      "definition": "A complete sequence of rounds (typically 5) that produces one cumulative score."
    },
    {
      "term": "Session Score",
      "definition": "The sum of all individual round scores within one session, plus any applicable streak bonuses."
    },
    {
      "term": "Proximity Score",
      "definition": "The points awarded for a single round, determined by how many years separate the player's guess from the correct answer."
    },
    {
      "term": "Banded Scoring",
      "definition": "A scoring system in which the penalty for each additional year of error varies \u2014 steeper near zero error, flatter at high error distances \u2014 rather than being constant across all error distances."
    },
    {
      "term": "Score Threshold",
      "definition": "A specific error distance at which the scoring curve changes slope, creating a noticeable shift in how many points each additional year of accuracy earns."
    },
    {
      "term": "Time Budget",
      "definition": "The total time available within a session, treated as a shared resource to be allocated across all rounds rather than consumed independently in each."
    },
    {
      "term": "Streak",
      "definition": "A counter tracking consecutive rounds where the player's score exceeds a defined threshold (e.g., scoring above 800 on three rounds in a row)."
    },
    {
      "term": "Streak Bonus",
      "definition": "Additional points or multipliers awarded for maintaining a streak across multiple consecutive rounds."
    },
    {
      "term": "Streak Threshold",
      "definition": "The minimum round score required to maintain a streak (typically approximately 800 in most TimeGuesser variants)."
    },
    {
      "term": "Clue Category",
      "definition": "A distinct type of visual information that can signal a temporal range. The five core categories are: Technology, Photography and Film Characteristics, Fashion, Typography and Print Media, and Architecture and Environment."
    },
    {
      "term": "Diagnostic Power",
      "definition": "How precisely a given clue can narrow the date range. High-diagnostic clues constrain an estimate to within a decade or less; low-diagnostic clues constrain to multiple decades."
    },
    {
      "term": "Clue Reliability",
      "definition": "The probability that a correctly identified clue accurately narrows the date range. High-reliability clues have narrow, well-documented date windows; low-reliability clues have wide windows or are subject to revivals."
    },
    {
      "term": "Clue Independence",
      "definition": "Two clues are independent if they draw on different underlying causes. Independent clues multiply triangulation power; correlated clues (sharing a common underlying cause) do not."
    },
    {
      "term": "Triangulation",
      "definition": "The process of combining two or more independent clues from different categories to produce a more precise year estimate than any single clue could provide."
    },
    {
      "term": "Anchoring Bias",
      "definition": "The tendency to rely too heavily on the first piece of information encountered when making an estimate, causing subsequent information to be underweighted."
    },
    {
      "term": "Anti-Anchoring Protocol",
      "definition": "A deliberate practice of seeking disconfirming evidence after forming an initial estimate before committing to a final guess. The key question: 'What clues would push my estimate later? What would push it earlier?'"
    },
    {
      "term": "Confidence-Based Commitment Rule (CBCR)",
      "definition": "A heuristic for deciding when to submit a round guess: commit once triangulation produces a range of 10 years or less AND no additional clue categories remain to be scanned."
    },
    {
      "term": "Effort Allocation",
      "definition": "The deliberate distribution of cognitive investment across all rounds in a session, prioritising rounds where extra effort produces the highest expected point return."
    },
    {
      "term": "Tier 1 Round",
      "definition": "A readable round containing multiple reliable, visible clues. Warrants full triangulation across all five clue categories."
    },
    {
      "term": "Tier 2 Round",
      "definition": "An unreadable or sparse round where clue scanning plateaus quickly due to limited visual information. Warrants early commitment via Quick Calibration rather than full triangulation."
    },
    {
      "term": "Quick Calibration",
      "definition": "A condensed version of triangulation used on Tier 2 rounds: identify one or two highest-diagnostic clues available, form a best estimate from those, and commit early."
    },
    {
      "term": "Domain-General Skill",
      "definition": "A cognitive operation that transfers across different tasks and contexts because it depends on reasoning processes, not domain-specific knowledge. The five domain-general skills in this course are: clue scanning, signal weighting, triangulation, calibrated commitment, and session management."
    },
    {
      "term": "New Game Onboarding Checklist",
      "definition": "A structured six-step framework for approaching any unfamiliar daily guessing game strategically from day one: (1) understand the scoring engine; (2) identify clue categories; (3) identify high-diagnostic clues; (4) define the calibrated commitment threshold; (5) identify the session structure; (6) play one calibration session."
    }
  ]
