<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Home</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div class="container">
    <h1>Welcome to the Homepage</h1>
    <p>Select a page below. Links are generated automatically from the <code>data/</code> directory.</p>
    <ul>
      <% it.pages.forEach(function(page) { %>
        <li><a href="/<%= page %>"><%= page %></a></li>
      <% }) %>
    </ul>
  </div>
</body>
</html>
