          "contentBlocks": [
            {
              "blockId": "intro-text",
              "type": "text",
              "content": "People frequently mistake correlation for causation in everyday reasoning."
            },
            {
              "blockId": "example-image",
              "type": "image",
              "url": "https://example.com/chart.png",
              "altText": "Scatterplot showing correlation between variables"
            }
          ],

          "interactionSequence": [
            {
              "interactionId": "prediction-01",
              "interactionType": "prediction",

              "prompt": "A city notices that neighborhoods with more parks have lower crime rates. Does this prove parks reduce crime?",

              "required": true,

              "responseFormat": "short-answer",

              "revealCondition": "after-response",

              "confidencePrompt": {
                "enabled": true,
                "scaleMin": 1,
                "scaleMax": 5,
                "prompt": "How confident are you in your answer?"
              }
            },

            {
              "interactionId": "compare-responses-01",
              "interactionType": "compare-responses",

              "responseModels": {
                "expertResponse": {
                  "answer": "The correlation alone does not prove causation because confounding variables may exist.",
                  "reasoningSteps": [
                    "Identify the observed correlation",
                    "Search for alternative explanations",
                    "Consider reverse causality",
                    "Evaluate evidence quality"
                  ]
                },

                "strongLearnerResponse": {
                  "answer": "There may be another factor causing both the parks and lower crime."
                },

                "weakResponse": {
                  "answer": "Yes, the parks probably caused the crime reduction.",
                  "diagnosis": [
                    "Assumes correlation proves causation",
                    "Does not evaluate confounding variables"
                  ]
                }
              }
            },

            {
              "interactionId": "reflection-01",
              "interactionType": "reflection",

              "prompt": "What assumption did you initially make when evaluating this claim?",

              "timing": "post-feedback"
            }
          ],

          "workedExamples": [
            {
              "exampleId": "worked-example-01",

              "problem": "Ice cream sales and drowning deaths rise together during summer months.",

              "steps": [
                "Identify correlation",
                "Search for shared causes",
                "Evaluate seasonal variables"
              ],

              "conclusion": "Temperature is a confounding variable affecting both."
            }
          ],

          "retrievalPractice": [
            {
              "retrievalItemId": "retrieval-01",

              "retrievalType": "free-recall",

              "prompt": "Name three possible explanations for a correlation.",

              "difficulty": 2,

              "schedule": {
                "initialReviewDays": 1,
                "subsequentReviewDays": [
                  3,
                  7,
                  14,
                  30
                ]
              }
            }
          ],

          "transferExercises": [
